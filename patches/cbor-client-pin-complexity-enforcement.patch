+// --- PIN Complexity Helpers ---
+static bool is_sequential(const uint8_t *pin, size_t pin_len) {
+    if (pin_len < 2) return false;
+
+    bool ascending = true;
+    bool descending = true;
+
+    for (size_t i = 1; i < pin_len; i++) {
+        if (pin[i] != pin[i-1] + 1) {
+            ascending = false;
+        }
+        if (pin[i] != pin[i-1] - 1) {
+            descending = false;
+        }
+    }
+    return ascending || descending;
+}
+
+static bool is_repeated(const uint8_t *pin, size_t pin_len) {
+    if (pin_len < 2) return false;
+    uint8_t first = pin[0];
+    for (size_t i = 1; i < pin_len; i++) {
+        if (pin[i] != first) return false;
+    }
+    return true;
+}
+
+static bool is_palindrome(const uint8_t *pin, size_t pin_len) {
+    if (pin_len <= 1) return true;
+    for (size_t i = 0; i < pin_len / 2; i++) {
+        if (pin[i] != pin[pin_len - 1 - i]) return false;
+    }
+    return true;
+}
+
+static bool has_excessive_repeats(const uint8_t *pin, size_t pin_len) {
+    if (pin_len < 3) return false;
+    for (size_t i = 0; i < pin_len - 2; i++) {
+        if (pin[i] == pin[i+1] && pin[i] == pin[i+2]) return true;
+    }
+    return false;
+}
+
+static int check_pin_complexity(const uint8_t *pin, size_t pin_len) {
+    if (!pin || pin_len == 0) {
+        return CTAP2_ERR_PIN_POLICY_VIOLATION;
+    }
+
+    bool has_digit = false, has_upper = false, has_lower = false, has_special = false;
+    bool is_all_digits = true;
+
+    // Character Analysis
+    for (size_t i = 0; i < pin_len; i++) {
+        if (pin[i] >= '0' && pin[i] <= '9') {
+            has_digit = true;
+        } else if (pin[i] >= 'A' && pin[i] <= 'Z') {
+            has_upper = true;
+            is_all_digits = false;
+        } else if (pin[i] >= 'a' && pin[i] <= 'z') {
+            has_lower = true;
+            is_all_digits = false;
+        } else {
+            has_special = true;
+            is_all_digits = false;
+        }
+    }
+
+    // Length & Category Rules
+    if (is_all_digits) {
+        if (pin_len < 6) return CTAP2_ERR_PIN_POLICY_VIOLATION;
+    } else {
+        if (pin_len < 8) return CTAP2_ERR_PIN_POLICY_VIOLATION;
+
+        int categories = (has_digit ? 1 : 0) + (has_upper ? 1 : 0) +
+                         (has_lower ? 1 : 0) + (has_special ? 1 : 0);
+        if (categories < 2) return CTAP2_ERR_PIN_POLICY_VIOLATION;
+    }
+
+    // Structural Rules
+    if (is_sequential(pin, pin_len) ||
+        is_repeated(pin, pin_len) ||
+        is_palindrome(pin, pin_len) ||
+        has_excessive_repeats(pin, pin_len)) {
+        return CTAP2_ERR_PIN_POLICY_VIOLATION;
+    }
+
+    return 0;
+}
